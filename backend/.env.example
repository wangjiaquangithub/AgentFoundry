# AgentScope enterprise knowledge assistant example
#
# This service reads regular environment variables with os.getenv.
# To use this file locally:
#   cp .env.example .env
#   set -a; source .env; set +a

# Service
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=1
CORS_ALLOW_ORIGINS=*

# Redis storage and optional Redis message bus
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
AGENTSCOPE_REDIS_BUS=0

# RAG indexing and vector store
AGENTSCOPE_ENABLE_INDEX_WORKER=1
QDRANT_URL=
QDRANT_API_KEY=

# Enterprise data connector
# mock: use the built-in Acme/Globex fixture data.
# mock + ENTERPRISE_FIXTURE_PATH: load tenant data from a JSON file.
# http: call an internal enterprise HTTP gateway.
ENTERPRISE_CONNECTOR=mock
ENTERPRISE_FIXTURE_PATH=
ENTERPRISE_API_BASE_URL=https://internal-api.example.com
ENTERPRISE_API_TOKEN=
ENTERPRISE_API_TIMEOUT_SECONDS=5
ENTERPRISE_POLICY_PATH=/tenants/{tenant}/policies/search
ENTERPRISE_TICKET_PATH=/tenants/{tenant}/tickets/{ticket_id}
ENTERPRISE_METRICS_PATH=/tenants/{tenant}/departments/{department}/metrics

# Enterprise audit
# Tool calls are written as compact JSONL events by default.
ENTERPRISE_AUDIT_ENABLED=1
ENTERPRISE_AUDIT_LOG_PATH=

# Enterprise tool authorization
# permissive: allow tools without explicit policy entries.
# strict: deny tools without explicit policy entries.
ENTERPRISE_TOOL_POLICY_PATH=
ENTERPRISE_TOOL_POLICY_MODE=permissive

# Optional model router for the platform Agent business Q&A demo.
# Leave these empty to use the built-in rules fallback only.
ENTERPRISE_AGENT_ROUTER_BASE_URL=
ENTERPRISE_AGENT_ROUTER_API_KEY=
ENTERPRISE_AGENT_ROUTER_MODEL=
ENTERPRISE_AGENT_ROUTER_PROVIDER=openai
ENTERPRISE_AGENT_ROUTER_TIMEOUT_SECONDS=8

# Model credentials are usually created through the AgentScope app service
# API or Web UI, then referenced by sessions. Keep real model API keys out of
# this example file unless your deployment explicitly loads them elsewhere.
